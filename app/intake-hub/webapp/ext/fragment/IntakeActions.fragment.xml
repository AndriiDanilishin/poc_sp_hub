<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m">
	<VBox id="IntakeActionsBox" core:require="{ handler: 'poc/sp/hub/intakehub/ext/fragment/IntakeActions'}">
		<Text text="Run AI extraction on this document's content to propose Workspace requirements." class="sapUiSmallMarginBottom" />
		<Button
			id="ExtractButton"
			text="Extract Requirements"
			type="Emphasized"
			icon="sap-icon://ai"
			press="handler.onExtract" />
		<Text
			text="Move this document to a different workspace. Only possible before extraction — once extracted, its requirements already live in the current workspace."
			class="sapUiMediumMarginTop sapUiSmallMarginBottom" />
		<Button
			id="ChangeWorkspaceButton"
			text="Change Workspace"
			icon="sap-icon://move"
			enabled="{path: 'status', formatter: 'handler.formatMoveEnabled'}"
			press="handler.onChangeWorkspace" />
	</VBox>
</core:FragmentDefinition>
