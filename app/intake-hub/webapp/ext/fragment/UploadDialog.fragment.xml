<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:u="sap.ui.unified"
    xmlns:f="sap.ui.layout.form">
    <!-- Every control carries an explicit id: manifest.json sets flexEnabled:true,
         which requires stable IDs for UI adaptation.

         Form + ColumnLayout, not SimpleForm: SimpleForm is ruled out by current
         UI5 guidance, and its implicit label/field alternation previously forced
         two <Label text="" /> spacers here purely to keep the pairing aligned —
         which screen readers announced as unlabeled fields. FormElement renders a
         field with no label correctly, so the spacers are gone. -->
    <Dialog id="uploadDialog" title="{i18n>uploadDialogTitle}" contentWidth="36rem">
        <content>
            <f:Form id="uploadForm" editable="true">
                <f:layout>
                    <f:ColumnLayout
                        id="uploadFormLayout"
                        columnsM="1"
                        columnsL="1"
                        columnsXL="1"
                        labelCellsLarge="4" />
                </f:layout>
                <f:formContainers>
                    <f:FormContainer id="uploadFormContainer">
                        <f:formElements>
                            <!-- Select + "new workspace" button as two sibling fields,
                                 NOT wrapped in an HBox: unlike SimpleForm, ColumnLayout
                                 validates its content and throws "is not a valid Form
                                 content!" during render for a layout container, which
                                 aborts the whole dialog. ColumnLayout lays multiple
                                 fields out on one row natively, with cellsSmall/Large
                                 splitting the 12-cell row between them. -->
                            <f:FormElement id="uploadWorkspaceElement" label="{i18n>uploadWorkspaceLabel}">
                                <f:fields>
                                    <Select
                                        id="uploadWorkspaceSelect"
                                        width="100%"
                                        required="true"
                                        forceSelection="false"
                                        change="onFieldChange">
                                        <layoutData>
                                            <f:ColumnElementData id="uploadWorkspaceSelectLayout" cellsSmall="10" cellsLarge="10" />
                                        </layoutData>
                                    </Select>
                                    <Button
                                        id="uploadNewWorkspaceBtn"
                                        icon="sap-icon://add"
                                        tooltip="{i18n>uploadNewWorkspaceTooltip}"
                                        press="onNewWorkspace">
                                        <layoutData>
                                            <f:ColumnElementData id="uploadNewWorkspaceBtnLayout" cellsSmall="2" cellsLarge="2" />
                                        </layoutData>
                                    </Button>
                                </f:fields>
                            </f:FormElement>

                            <!-- Picking a file auto-fills the name, type and origin
                                 fields below; all of them stay editable afterwards.
                                 The accepted fileType list must stay in sync with
                                 ACCEPTED_EXTENSIONS in UploadDialog.js. -->
                            <f:FormElement id="uploadFileElement" label="{i18n>uploadFileLabel}">
                                <f:fields>
                                    <u:FileUploader
                                        id="uploadFileUploader"
                                        width="100%"
                                        maximumFileSize="10"
                                        fileType="pdf,csv,tsv,eml,json,txt,md,xml"
                                        change="onFileSelected"
                                        typeMissmatch="onFileTypeMissmatch"
                                        fileSizeExceed="onFileSizeExceed" />
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement id="uploadFileHintElement">
                                <f:fields>
                                    <!-- Text is set in onOpenUpload, not bound: the
                                         string takes the size cap as {0}, and a
                                         plain {i18n>…} binding passes no parameter,
                                         so it rendered "max {0} MB" literally.
                                         MAX_UPLOAD_MB lives in the controller. -->
                                    <Text id="uploadFileHint" />
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement id="uploadOriginTypeElement" label="{i18n>uploadOriginTypeLabel}">
                                <f:fields>
                                    <Select
                                        id="uploadOriginType"
                                        width="100%"
                                        required="true"
                                        selectedKey="Text">
                                        <core:Item id="uploadOriginTypeText" key="Text" text="{i18n>originTypeText}" />
                                        <core:Item id="uploadOriginTypeEmail" key="Email" text="{i18n>originTypeEmail}" />
                                        <core:Item id="uploadOriginTypeExcel" key="Excel" text="{i18n>originTypeExcel}" />
                                        <core:Item id="uploadOriginTypeRest" key="RestApi" text="{i18n>originTypeRestApi}" />
                                        <core:Item id="uploadOriginTypePdf" key="Pdf" text="{i18n>originTypePdf}" />
                                        <core:Item id="uploadOriginTypeImage" key="Image" text="{i18n>originTypeImage}" />
                                    </Select>
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement id="uploadFileNameElement" label="{i18n>uploadFileNameLabel}">
                                <f:fields>
                                    <Input
                                        id="uploadFileName"
                                        required="true"
                                        placeholder="{i18n>uploadFileNamePlaceholder}"
                                        liveChange="onFieldChange"
                                        width="100%" />
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement id="uploadFileTypeElement" label="{i18n>uploadFileTypeLabel}">
                                <f:fields>
                                    <Input
                                        id="uploadFileType"
                                        placeholder="{i18n>uploadFileTypePlaceholder}"
                                        width="100%" />
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement id="uploadContentElement" label="{i18n>uploadContentLabel}">
                                <f:fields>
                                    <TextArea
                                        id="uploadContent"
                                        width="100%"
                                        rows="6"
                                        growing="true"
                                        growingMaxLines="14"
                                        liveChange="onFieldChange"
                                        placeholder="{i18n>uploadContentPlaceholder}" />
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement id="uploadAutoExtractElement">
                                <f:fields>
                                    <CheckBox id="uploadAutoExtract" text="{i18n>uploadAutoExtract}" />
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>
                </f:formContainers>
            </f:Form>
        </content>
        <beginButton>
            <Button
                id="uploadConfirmBtn"
                text="{i18n>uploadConfirmButton}"
                type="Emphasized"
                press="onConfirmUpload" />
        </beginButton>
        <endButton>
            <Button id="uploadCancelBtn" text="{i18n>cancelButton}" press="onCancelUpload" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
