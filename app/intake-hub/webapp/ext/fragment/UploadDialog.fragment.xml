<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout.form">
    <Dialog id="uploadDialog" title="Upload Document" contentWidth="34rem">
        <content>
            <l:SimpleForm
                id="uploadForm"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                editable="true">
                <l:content>
                    <Label text="Target Workspace" required="true" />
                    <Select
                        id="uploadWorkspaceSelect"
                        width="100%"
                        forceSelection="false"
                        items="{path: '/RequirementWorkspaces', parameters: {$orderby: 'createdAt desc'}, filters: [{path: 'status', operator: 'EQ', value1: 'OPEN'}]}">
                        <core:Item key="{ID}" text="{title}" />
                    </Select>

                    <Label text="Origin Type" required="true" />
                    <Select id="uploadOriginType" width="100%" selectedKey="Text">
                        <core:Item key="Text" text="Plain Text" />
                        <core:Item key="Email" text="Email" />
                        <core:Item key="Excel" text="Excel (CSV/TSV)" />
                        <core:Item key="RestApi" text="REST API (JSON)" />
                        <core:Item key="Pdf" text="PDF" />
                        <core:Item key="Image" text="Image" />
                    </Select>

                    <Label text="File Name" required="true" />
                    <Input id="uploadFileName" placeholder="e.g. lab-request.eml" width="100%" />

                    <Label text="File Type" />
                    <Input id="uploadFileType" placeholder="e.g. eml, csv, json" width="100%" />

                    <Label text="Content" />
                    <TextArea
                        id="uploadContent"
                        width="100%"
                        rows="8"
                        growing="true"
                        growingMaxLines="16"
                        placeholder="Paste the document's raw text (email body, CSV rows, JSON payload). Binary formats can be uploaded without content and parsed later." />
                </l:content>
            </l:SimpleForm>
        </content>
        <beginButton>
            <Button
                id="uploadConfirmBtn"
                text="Upload"
                type="Emphasized"
                press="onConfirmUpload" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelUpload" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
