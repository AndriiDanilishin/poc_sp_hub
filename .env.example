# AI provider configuration for the Intake/enrichment/drafting pipeline.
#
# Copy this file to `.env` (which is gitignored) and fill in your key.
# The project's srv/server.js bootstrap loads this .env at startup via Node's
# built-in process.loadEnvFile (no dotenv dependency). @sap/cds does NOT read
# .env on its own — server.js is what wires it in, for any launch method
# (cds watch / cds serve / npm start). Restart after changing these; env is not
# hot-reloaded. A real shell-exported var (e.g. OPENAI_API_KEY) overrides .env.
#
# THIS FILE IS COMMITTED — never put a real key here. Real keys go in .env only.

# Provider: 'mock' (default, offline, deterministic placeholder output — no key
# needed) or 'openai' (real extraction that reads document content).
AI_PROVIDER=openai

# Required when AI_PROVIDER=openai. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional — models. Defaults shown; override only if needed.
# The embed model's dimensionality MUST match the Vector(N) column in
# db/sourcing-schema.cds. text-embedding-3-small = 1536 (default, widely
# accessible); text-embedding-3-large = 3072 (needs project access to that model
# AND the column changed to Vector(3072)). Change model + column together.
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBED_MODEL=text-embedding-3-small

# Optional — point at an OpenAI-compatible endpoint (e.g. Azure OpenAI, a proxy,
# or SAP Generative AI Hub's OpenAI-compatible route). Defaults to OpenAI direct.
# OPENAI_BASE_URL=https://api.openai.com/v1
